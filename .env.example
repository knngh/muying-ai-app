# ===========================================
# 服务器配置
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# 数据库配置
# ===========================================
# 连接池参数说明：
# - connection_limit: 连接池大小，默认10，生产环境建议20-30
# - pool_timeout: 获取连接超时时间（秒），默认30
# - connect_timeout: 连接建立超时时间（秒），默认10
DATABASE_URL="mysql://user:password@localhost:3306/muying_web?connection_limit=20&pool_timeout=30"

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# AI API 配置（可选）
# ===========================================
KIMI_API_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_API_KEY=your-kimi-api-key