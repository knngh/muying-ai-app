# ===========================================
# 服务器配置
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# 数据库配置
# ===========================================
# 连接池参数说明：
# - connection_limit: 连接池大小，默认10，生产环境建议20-30
# - pool_timeout: 获取连接超时时间（秒），默认30
# - connect_timeout: 连接建立超时时间（秒），默认10
DATABASE_URL="mysql://user:password@localhost:3306/muying_web?connection_limit=20&pool_timeout=30"

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# AI 统一路由配置（OpenRouter）
# ===========================================
# 当前默认将普通问答、医疗问答与任务模型统一到：
# - MiniMax OpenAI-compatible API
# - MiniMax-M2.7
AI_ROUTING_ENABLED=true
AI_DEFAULT_MODEL=MiniMax-M2.7

# 统一网关 / 兜底通道
AI_GATEWAY_URL=https://api.minimaxi.com/v1
AI_GATEWAY_KEY=your-minimax-api-key
AI_OPENROUTER_URL=https://api.minimaxi.com/v1
AI_OPENROUTER_KEY=your-minimax-api-key
AI_OPENROUTER_MODEL=MiniMax-M2.7
AI_OPENROUTER_PROVIDER=minimax
AI_OPENROUTER_SITE_URL=
AI_OPENROUTER_APP_NAME=

# 任务路由默认全部复用同一模型
AI_GLM_URL=https://api.minimaxi.com/v1
AI_GLM_KEY=your-minimax-api-key
AI_GLM_MODEL=MiniMax-M2.7
AI_GLM_PROVIDER=minimax

AI_KIMI_URL=https://api.minimaxi.com/v1
AI_KIMI_KEY=your-minimax-api-key
AI_KIMI_MODEL=MiniMax-M2.7
AI_KIMI_PROVIDER=minimax

AI_MINIMAX_URL=https://api.minimaxi.com/v1
AI_MINIMAX_KEY=your-minimax-api-key
AI_MINIMAX_MODEL=MiniMax-M2.7
AI_MINIMAX_PROVIDER=minimax

# AI 服务备案/公示信息（前端会随 AI 响应展示）
AI_DISCLOSURE_PROVIDER=minimax
AI_DISCLOSURE_PROVIDER_NAME=MiniMax
AI_DISCLOSURE_COMPANY_NAME=上海稀宇科技有限公司
AI_DISCLOSURE_MODEL_NAME=MiniMax-M2.7
AI_DISCLOSURE_FILING_CODE=Shanghai-Abab-20230821
AI_DISCLOSURE_SERVICE_NAME=贝护妈妈阅读问答
AI_DISCLOSURE_SERVICE_TYPE=生成式人工智能服务（母婴健康信息参考）
AI_DISCLOSURE_COMPLAINT_EMAIL=
AI_DISCLOSURE_UPDATED_AT=2026-04-26
AI_DISCLOSURE_PUBLIC_NOTICE=
AI_DISCLOSURE_DISCLAIMER=本服务提供母婴健康信息参考，不提供诊断、治疗或用药决策，不能替代医生面诊；紧急情况请及时就医。

AI_GENERAL_URL=https://api.minimaxi.com/v1
AI_GENERAL_KEY=your-minimax-api-key
AI_GENERAL_MODEL=MiniMax-M2.7
AI_GENERAL_PROVIDER=minimax

# 医疗主通道默认也走同一模型，备通道按需留空
AI_MEDICAL_PRIMARY_URL=https://api.minimaxi.com/v1
AI_MEDICAL_PRIMARY_KEY=your-minimax-api-key
AI_MEDICAL_PRIMARY_MODEL=MiniMax-M2.7
AI_MEDICAL_PRIMARY_PROVIDER=minimax
AI_MEDICAL_SECONDARY_URL=
AI_MEDICAL_SECONDARY_KEY=
AI_MEDICAL_SECONDARY_MODEL=
AI_MEDICAL_SECONDARY_PROVIDER=
AI_PROVIDER_TIMEOUT_MS=25000

# 向量库可选
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=
ZILLIZ_PUBLIC_ENDPOINT=
ZILLIZ_TOKEN=
AUTHORITY_VECTOR_PUBLISH_ENABLED=false
AUTHORITY_OCR_COMMAND='tesseract {input} stdout -l chi_sim+eng --psm 6'
AUTHORITY_OCR_LIMIT=10
AUTHORITY_OCR_MIN_TEXT_LENGTH=150
AUTHORITY_OCR_TIMEOUT_MS=120000
AUTHORITY_OCR_DRY_RUN=false
AUTHORITY_TRANSLATION_CACHE_PATH=./data/authority-translation-cache.json
AUTHORITY_TRANSLATION_FAILURE_CACHE_PATH=./data/authority-translation-failures.json
AUTHORITY_TRANSLATION_WAIT_TIMEOUT_MS=16000
AUTHORITY_TRANSLATION_PROVIDER_TIMEOUT_MS=45000
AUTHORITY_TRANSLATION_TASK_ROLES=minimax_render
AUTHORITY_TRANSLATION_LIST_PREWARM_LIMIT=0
AUTHORITY_TRANSLATION_SYNC_ENABLED=true
AUTHORITY_TRANSLATION_SYNC_LIMIT=10
AUTHORITY_TRANSLATION_SYNC_DELAY_MS=30000
AUTHORITY_TRANSLATION_SYNC_SOURCE_LANGUAGE=en
AUTHORITY_TRANSLATION_WARMUP_INTERVAL_MINUTES=15
AUTHORITY_TRANSLATION_SOURCE_CHAR_LIMIT=3200
AUTHORITY_TRANSLATION_MAX_TOKENS=1600

# Embedding API 配置
# 说明：
# - Milvus 只负责存储/检索向量，不负责生成向量
# - 这里必须配置 embedding 模型，不要填聊天模型
# - 若从 Qwen 4096 维切到 BAAI/bge-m3 1024 维，需改新集合名或重建旧集合后重新灌库
# - 为弥补 bge-m3 纯 dense 检索损失，建议保持 AI_KNOWLEDGE_RERANK=true
# - 默认优先调用 SiliconFlow /v1/rerank 的 BAAI/bge-reranker-v2-m3，失败再回退到 MiniMax
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
MILVUS_COLLECTION_NAME=muying_knowledge_bge_m3_filtered
AI_KNOWLEDGE_RERANK=true
AI_KNOWLEDGE_RERANK_CANDIDATE_LIMIT=8
RERANK_API_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ===========================================
# 支付回调签名配置（可选，建议生产启用）
# ===========================================
# 回调签名头：
# - X-Payment-Timestamp
# - X-Payment-Signature
# 签名串格式：
# provider=<provider>\n
# timestamp=<timestamp>\n
# orderNo=<orderNo>\n
# tradeNo=<tradeNo>\n
# paymentStatus=<paymentStatus>\n
# amount=<amount>
WECHAT_PAYMENT_CALLBACK_SECRET=
ALIPAY_PAYMENT_CALLBACK_SECRET=

# 未接入真实支付网关前，可保留 true 以允许登录态 mock confirm
PAYMENT_CALLBACK_ALLOW_AUTH_FALLBACK=true
PAYMENT_CALLBACK_MAX_SKEW_SECONDS=300
