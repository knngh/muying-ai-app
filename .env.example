# ===========================================
# 服务器配置
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# 数据库配置
# ===========================================
# 连接池参数说明：
# - connection_limit: 连接池大小，默认10，生产环境建议20-30
# - pool_timeout: 获取连接超时时间（秒），默认30
# - connect_timeout: 连接建立超时时间（秒），默认10
DATABASE_URL="mysql://user:password@localhost:3306/muying_web?connection_limit=20&pool_timeout=30"

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# AI API 配置（可选）
# ===========================================
AI_GATEWAY_URL=https://api.example.com/v1
AI_GATEWAY_KEY=your-ai-gateway-key
AI_DEFAULT_MODEL=glm-4-flash

# ===========================================
# AI 混合路由配置（可选，推荐用于日常 DeepSeek + 医疗升级通道）
# ===========================================
# 开启后：
# - 普通育儿/日常问答优先走 AI_GENERAL_*
# - 疾病、用药、检查单等医疗问题优先走 AI_MEDICAL_PRIMARY_*
# - 如升级通道失败，会自动回退到旧的 AI_GATEWAY_* 配置
AI_ROUTING_ENABLED=false

# 日常问答层：DeepSeek（示例为 SiliconFlow OpenAI 兼容地址）
AI_GENERAL_URL=https://api.siliconflow.cn/v1/chat/completions
AI_GENERAL_KEY=
AI_GENERAL_MODEL=deepseek-ai/DeepSeek-V3
AI_GENERAL_PROVIDER=siliconflow

# 医疗咨询层主通道：可接百川 M3 Plus / 专业医疗 API
AI_MEDICAL_PRIMARY_URL=
AI_MEDICAL_PRIMARY_KEY=
AI_MEDICAL_PRIMARY_MODEL=baichuan-m3
AI_MEDICAL_PRIMARY_PROVIDER=baichuan

# 医疗咨询层备用通道：如蚂蚁·安诊儿 / 付费医疗咨询 API
AI_MEDICAL_SECONDARY_URL=
AI_MEDICAL_SECONDARY_KEY=
AI_MEDICAL_SECONDARY_MODEL=
AI_MEDICAL_SECONDARY_PROVIDER=

# ===========================================
# 支付回调签名配置（可选，建议生产启用）
# ===========================================
# 回调签名头：
# - X-Payment-Timestamp
# - X-Payment-Signature
# 签名串格式：
# provider=<provider>\n
# timestamp=<timestamp>\n
# orderNo=<orderNo>\n
# tradeNo=<tradeNo>\n
# paymentStatus=<paymentStatus>\n
# amount=<amount>
WECHAT_PAYMENT_CALLBACK_SECRET=
ALIPAY_PAYMENT_CALLBACK_SECRET=

# 未接入真实支付网关前，可保留 true 以允许登录态 mock confirm
PAYMENT_CALLBACK_ALLOW_AUTH_FALLBACK=true
PAYMENT_CALLBACK_MAX_SKEW_SECONDS=300
