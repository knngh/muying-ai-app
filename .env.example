# ===========================================
# 服务器配置
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# 数据库配置
# ===========================================
# 连接池参数说明：
# - connection_limit: 连接池大小，默认10，生产环境建议20-30
# - pool_timeout: 获取连接超时时间（秒），默认30
# - connect_timeout: 连接建立超时时间（秒），默认10
DATABASE_URL="mysql://user:password@localhost:3306/muying_web?connection_limit=20&pool_timeout=30"

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# AI 统一路由配置（OpenRouter）
# ===========================================
# 当前默认将普通问答、医疗问答与任务模型统一到：
# - MiniMax OpenAI-compatible API
# - MiniMax-M2.7
AI_ROUTING_ENABLED=true
AI_DEFAULT_MODEL=MiniMax-M2.7

# 统一网关 / 兜底通道
AI_GATEWAY_URL=https://api.minimaxi.com/v1
AI_GATEWAY_KEY=your-minimax-api-key
AI_OPENROUTER_URL=https://api.minimaxi.com/v1
AI_OPENROUTER_KEY=your-minimax-api-key
AI_OPENROUTER_MODEL=MiniMax-M2.7
AI_OPENROUTER_PROVIDER=minimax
AI_OPENROUTER_SITE_URL=
AI_OPENROUTER_APP_NAME=

# 任务路由默认全部复用同一模型
AI_GLM_URL=https://api.minimaxi.com/v1
AI_GLM_KEY=your-minimax-api-key
AI_GLM_MODEL=MiniMax-M2.7
AI_GLM_PROVIDER=minimax

AI_KIMI_URL=https://api.minimaxi.com/v1
AI_KIMI_KEY=your-minimax-api-key
AI_KIMI_MODEL=MiniMax-M2.7
AI_KIMI_PROVIDER=minimax

AI_MINIMAX_URL=https://api.minimaxi.com/v1
AI_MINIMAX_KEY=your-minimax-api-key
AI_MINIMAX_MODEL=MiniMax-M2.7
AI_MINIMAX_PROVIDER=minimax

AI_GENERAL_URL=https://api.minimaxi.com/v1
AI_GENERAL_KEY=your-minimax-api-key
AI_GENERAL_MODEL=MiniMax-M2.7
AI_GENERAL_PROVIDER=minimax

# 医疗主通道默认也走同一模型，备通道按需留空
AI_MEDICAL_PRIMARY_URL=https://api.minimaxi.com/v1
AI_MEDICAL_PRIMARY_KEY=your-minimax-api-key
AI_MEDICAL_PRIMARY_MODEL=MiniMax-M2.7
AI_MEDICAL_PRIMARY_PROVIDER=minimax
AI_MEDICAL_SECONDARY_URL=
AI_MEDICAL_SECONDARY_KEY=
AI_MEDICAL_SECONDARY_MODEL=
AI_MEDICAL_SECONDARY_PROVIDER=
AI_PROVIDER_TIMEOUT_MS=25000

# 向量库可选
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=
ZILLIZ_PUBLIC_ENDPOINT=
ZILLIZ_TOKEN=
AUTHORITY_VECTOR_PUBLISH_ENABLED=false

# Embedding API 配置
# 说明：
# - Milvus 只负责存储/检索向量，不负责生成向量
# - 这里必须配置 embedding 模型，不要填聊天模型
# - 若与 AI_GATEWAY_* 共用同一条 OpenAI-compatible 网关，可只补模型名
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096
MILVUS_COLLECTION_NAME=muying_knowledge

# ===========================================
# 支付回调签名配置（可选，建议生产启用）
# ===========================================
# 回调签名头：
# - X-Payment-Timestamp
# - X-Payment-Signature
# 签名串格式：
# provider=<provider>\n
# timestamp=<timestamp>\n
# orderNo=<orderNo>\n
# tradeNo=<tradeNo>\n
# paymentStatus=<paymentStatus>\n
# amount=<amount>
WECHAT_PAYMENT_CALLBACK_SECRET=
ALIPAY_PAYMENT_CALLBACK_SECRET=

# 未接入真实支付网关前，可保留 true 以允许登录态 mock confirm
PAYMENT_CALLBACK_ALLOW_AUTH_FALLBACK=true
PAYMENT_CALLBACK_MAX_SKEW_SECONDS=300
