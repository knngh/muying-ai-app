# ===========================================
# 服务器配置
# ===========================================
NODE_ENV=development
PORT=3000
HOST=localhost

# ===========================================
# 数据库配置
# ===========================================
# 连接池参数说明：
# - connection_limit: 连接池大小，默认10，生产环境建议20-30
# - pool_timeout: 获取连接超时时间（秒），默认30
# - connect_timeout: 连接建立超时时间（秒），默认10
DATABASE_URL="mysql://user:password@localhost:3306/muying_web?connection_limit=20&pool_timeout=30"

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# CORS 配置
# ===========================================
CORS_ORIGIN=http://localhost:5173

# ===========================================
# AI 三模型路由配置（百炼）
# ===========================================
# 可信答疑使用三路：
# - GLM 5：分类 / 澄清 / FAQ
# - Kimi 2.5：理解 / 归纳 / 中风险判断
# - MiniMax 2.5：最终中文表达
AI_ROUTING_ENABLED=true
AI_DEFAULT_MODEL=glm-5

# 若已通过统一网关转发，可继续保留 AI_GATEWAY_* 作为兜底
AI_GATEWAY_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GATEWAY_KEY=your-bailian-api-key

# GLM 5
AI_GLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GLM_KEY=your-bailian-api-key
AI_GLM_MODEL=glm-5
AI_GLM_PROVIDER=glm

# Kimi 2.5
AI_KIMI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_KIMI_KEY=your-bailian-api-key
AI_KIMI_MODEL=kimi-k2.5
AI_KIMI_PROVIDER=kimi

# MiniMax 2.5
AI_MINIMAX_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MINIMAX_KEY=your-bailian-api-key
AI_MINIMAX_MODEL=minimax-2.5
AI_MINIMAX_PROVIDER=minimax

# 普通聊天通道，未显式路由时可复用 GLM 5
AI_GENERAL_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GENERAL_KEY=your-bailian-api-key
AI_GENERAL_MODEL=glm-5
AI_GENERAL_PROVIDER=glm

# 医疗主/备通道暂时复用三模型默认链路，可留空
AI_MEDICAL_PRIMARY_URL=
AI_MEDICAL_PRIMARY_KEY=
AI_MEDICAL_PRIMARY_MODEL=
AI_MEDICAL_PRIMARY_PROVIDER=
AI_MEDICAL_SECONDARY_URL=
AI_MEDICAL_SECONDARY_KEY=
AI_MEDICAL_SECONDARY_MODEL=
AI_MEDICAL_SECONDARY_PROVIDER=

# 向量库可选
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=
ZILLIZ_PUBLIC_ENDPOINT=
ZILLIZ_TOKEN=
AUTHORITY_VECTOR_PUBLISH_ENABLED=false

# Embedding API 配置
# 说明：
# - Milvus 只负责存储/检索向量，不负责生成向量
# - 这里必须配置 embedding 模型，不要填聊天模型
# - 若与 AI_GATEWAY_* 共用同一条 OpenAI-compatible 网关，可只补模型名
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096
MILVUS_COLLECTION_NAME=muying_knowledge

# ===========================================
# 支付回调签名配置（可选，建议生产启用）
# ===========================================
# 回调签名头：
# - X-Payment-Timestamp
# - X-Payment-Signature
# 签名串格式：
# provider=<provider>\n
# timestamp=<timestamp>\n
# orderNo=<orderNo>\n
# tradeNo=<tradeNo>\n
# paymentStatus=<paymentStatus>\n
# amount=<amount>
WECHAT_PAYMENT_CALLBACK_SECRET=
ALIPAY_PAYMENT_CALLBACK_SECRET=

# 未接入真实支付网关前，可保留 true 以允许登录态 mock confirm
PAYMENT_CALLBACK_ALLOW_AUTH_FALLBACK=true
PAYMENT_CALLBACK_MAX_SKEW_SECONDS=300
