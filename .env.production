# 生产环境配置
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# 数据库配置
DATABASE_URL="mysql://muying_user:your_secure_password@localhost:3306/muying_db?connection_limit=20&pool_timeout=30"

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://your-domain.com

# AI Gateway 配置
AI_ROUTING_ENABLED=true
AI_GATEWAY_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GATEWAY_KEY=your-bailian-api-key
AI_DEFAULT_MODEL=glm-5
AI_GLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GLM_KEY=your-bailian-api-key
AI_GLM_MODEL=glm-5
AI_GLM_PROVIDER=glm
AI_KIMI_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_KIMI_KEY=your-bailian-api-key
AI_KIMI_MODEL=kimi-k2.5
AI_KIMI_PROVIDER=kimi
AI_MINIMAX_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MINIMAX_KEY=your-bailian-api-key
AI_MINIMAX_MODEL=minimax-2.5
AI_MINIMAX_PROVIDER=minimax
AI_GENERAL_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_GENERAL_KEY=your-bailian-api-key
AI_GENERAL_MODEL=glm-5
AI_GENERAL_PROVIDER=glm

# Vector / Milvus
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=
ZILLIZ_PUBLIC_ENDPOINT=
ZILLIZ_TOKEN=
AUTHORITY_VECTOR_PUBLISH_ENABLED=false
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096
MILVUS_COLLECTION_NAME=muying_knowledge
