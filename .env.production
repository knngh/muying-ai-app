# 生产环境配置
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# 数据库配置
DATABASE_URL="mysql://muying_user:your_secure_password@localhost:3306/muying_db?connection_limit=20&pool_timeout=30"

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://your-domain.com

# AI Gateway 配置
AI_GATEWAY_URL=http://localhost:8080/v1
AI_GATEWAY_KEY=your-ai-gateway-key
AI_DEFAULT_MODEL=glm-4-flash