{
  "name": "muying-web-backend",
  "version": "1.0.0",
  "description": "母婴网页后端 API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed:community": "tsx src/scripts/seed-community.ts",
    "ops:sync:prod": "bash scripts/prod-sync-backend.sh",
    "ops:deploy:prod": "bash scripts/prod-deploy-backend.sh",
    "ops:release:prod": "bash scripts/prod-release-backend.sh",
    "ops:rollback:prod": "bash scripts/prod-rollback-backend.sh",
    "ops:smoke:prod": "bash scripts/prod-smoke-backend.sh",
    "ops:verify:payment-callback:prod": "bash scripts/prod-verify-payment-callback.sh",
    "ops:authority:rollout": "bash scripts/prod-authority-rollout.sh",
    "import:knowledge": "tsx src/scripts/import-knowledge.ts",
    "import:content": "tsx src/scripts/import-content-questions.ts",
    "sync:authority": "tsx src/scripts/sync-authority-sources.ts",
    "worker:authority": "tsx src/workers/authority-sync.worker.ts",
    "review:authority": "tsx src/scripts/review-authority-documents.ts",
    "generate:answers": "tsx src/scripts/generate-answers.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:unit": "jest --runInBand tests/mvp-route-guards.test.ts tests/mvp-security-regressions.test.ts tests/analytics-service.test.ts tests/subscription-quota.test.ts tests/payment-callback-signature.test.ts",
    "test:integration": "RUN_INTEGRATION_TESTS=true jest --runInBand tests/auth.test.ts tests/user-community.test.ts",
    "ops:sign:payment-callback": "node --import tsx scripts/generate-payment-callback-signature.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.5",
    "uuid": "^9.0.1",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
